-- ============================================================
-- SurrealDB Import: Räume (Raumprogramm)
-- Generiert aus: 07.xlsx - Raumprogramm 3.BA
-- ============================================================

-- Verwende existierende Namespace/Datenbank
USE NS university;
USE DB facilities;

-- ============================================================
-- Tabelle: teilprojekt
-- Definiert die Teilprojekte/Bauabschnitte
-- ============================================================
DEFINE TABLE IF NOT EXISTS teilprojekt SCHEMAFULL;
DEFINE FIELD name ON TABLE teilprojekt TYPE string;
DEFINE FIELD beschreibung ON TABLE teilprojekt TYPE option<string>;
DEFINE INDEX IF NOT EXISTS idx_teilprojekt_name ON TABLE teilprojekt COLUMNS name UNIQUE;

-- ============================================================
-- Tabelle: funktionsbereich
-- Definiert die Funktionsbereiche
-- ============================================================
DEFINE TABLE IF NOT EXISTS funktionsbereich SCHEMAFULL;
DEFINE FIELD name ON TABLE funktionsbereich TYPE string;
DEFINE FIELD beschreibung ON TABLE funktionsbereich TYPE option<string>;
DEFINE INDEX IF NOT EXISTS idx_funktionsbereich_name ON TABLE funktionsbereich COLUMNS name UNIQUE;

-- ============================================================
-- Tabelle: verortung
-- Definiert die möglichen Verortungen
-- ============================================================
DEFINE TABLE IF NOT EXISTS verortung SCHEMAFULL;
DEFINE FIELD name ON TABLE verortung TYPE string;
DEFINE INDEX IF NOT EXISTS idx_verortung_name ON TABLE verortung COLUMNS name UNIQUE;

-- ============================================================
-- Tabelle: raum
-- Haupttabelle für alle Räume
-- ============================================================
DEFINE TABLE IF NOT EXISTS raum SCHEMAFULL;

-- Grundlegende Informationen
DEFINE FIELD nummer ON TABLE raum TYPE int;
DEFINE FIELD bezeichnung ON TABLE raum TYPE string;
DEFINE FIELD nc5_code ON TABLE raum TYPE option<string>;
DEFINE FIELD nc5_bezeichnung ON TABLE raum TYPE option<string>;

-- Zuordnungen
DEFINE FIELD teil_der_beauftragung ON TABLE raum TYPE bool DEFAULT true;
DEFINE FIELD teilprojekt ON TABLE raum TYPE option<record<teilprojekt>>;
DEFINE FIELD nutzer_ebene_1 ON TABLE raum TYPE option<string>;
DEFINE FIELD nutzer_ebene_2 ON TABLE raum TYPE option<string>;
DEFINE FIELD funktionsbereich ON TABLE raum TYPE option<record<funktionsbereich>>;
DEFINE FIELD verortung ON TABLE raum TYPE option<record<verortung>>;
DEFINE FIELD raumtyp ON TABLE raum TYPE option<record<raumtyp>>;

-- Flächenangaben
DEFINE FIELD flaeche_nuf_1_6 ON TABLE raum TYPE option<float>;
DEFINE FIELD flaeche_nuf_7_9 ON TABLE raum TYPE option<float>;

-- Personenangaben
DEFINE FIELD personen_pro_raum ON TABLE raum TYPE option<int>;
DEFINE FIELD arbeitsplaetze_pro_raum ON TABLE raum TYPE option<int>;

-- Arbeitsplatz-Typen
DEFINE FIELD ap_typ_1_1 ON TABLE raum TYPE option<int>;
DEFINE FIELD ap_typ_1_2 ON TABLE raum TYPE option<int>;
DEFINE FIELD ap_typ_2 ON TABLE raum TYPE option<int>;

-- Elektroanschlüsse
DEFINE FIELD strom_230v_16a ON TABLE raum TYPE option<int>;
DEFINE FIELD strom_400v_16a ON TABLE raum TYPE option<int>;

-- DIN277 Klassifikation
DEFINE FIELD din277 ON TABLE raum TYPE option<string>;

-- Metadaten
DEFINE FIELD hinweise ON TABLE raum TYPE option<string>;
DEFINE FIELD erstellt_am ON TABLE raum TYPE option<datetime> DEFAULT time::now();

-- Indizes
DEFINE INDEX IF NOT EXISTS idx_raum_nummer ON TABLE raum COLUMNS nummer UNIQUE;
DEFINE INDEX IF NOT EXISTS idx_raum_raumtyp ON TABLE raum COLUMNS raumtyp;
DEFINE INDEX IF NOT EXISTS idx_raum_teilprojekt ON TABLE raum COLUMNS teilprojekt;
DEFINE INDEX IF NOT EXISTS idx_raum_verortung ON TABLE raum COLUMNS verortung;

-- ============================================================
-- Verortungen erstellen
-- ============================================================
CREATE verortung:neubau SET name = 'Neubau';
CREATE verortung:bestand SET name = 'Bestand';
CREATE verortung:bestandsbau SET name = 'Bestandsbau';
CREATE verortung:bestand_neubau SET name = 'Bestand / Neubau';
