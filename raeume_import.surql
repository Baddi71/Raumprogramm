-- ============================================================
-- Nützliche Abfragen
-- ============================================================

-- Alle Räume eines bestimmten Raumtyps:
-- SELECT * FROM raum WHERE raumtyp = raumtyp:fn_4_2;

-- Gesamtfläche pro Teilprojekt:
-- SELECT teilprojekt.name, math::sum(flaeche_nuf_1_6) AS gesamt_flaeche
-- FROM raum GROUP BY teilprojekt;

-- Räume im Neubau:
-- SELECT nummer, bezeichnung, raumtyp FROM raum WHERE verortung = verortung:neubau;

-- Anzahl Räume pro Raumtyp:
-- SELECT raumtyp, count() AS anzahl FROM raum GROUP BY raumtyp ORDER BY anzahl DESC;

-- Räume mit mehr als 2 Arbeitsplätzen:
-- SELECT nummer, bezeichnung, arbeitsplaetze_pro_raum FROM raum
-- WHERE arbeitsplaetze_pro_raum > 2 ORDER BY arbeitsplaetze_pro_raum DESC;

-- Gesamte Arbeitsplätze pro Funktionsbereich:
-- SELECT funktionsbereich.name, math::sum(arbeitsplaetze_pro_raum) AS total_ap
-- FROM raum GROUP BY funktionsbereich;

-- Räume mit ihren vollständigen Raumtyp-Informationen:
-- SELECT nummer, bezeichnung, raumtyp.* FROM raum FETCH raumtyp;

-- Alle Ausstattungstypen eines Raums über den Raumtyp:
-- SELECT nummer, bezeichnung, raumtyp->raumtyp_ausstattung->ausstattungstyp.*
-- FROM raum:1 FETCH raumtyp;

-- Gesamtbedarf an 230V Anschlüssen für alle Räume eines Typs:
-- SELECT
--   raumtyp.code,
--   count() AS anzahl_raeume,
--   math::sum(strom_230v_16a) AS total_230v
-- FROM raum
-- WHERE raumtyp = raumtyp:fn_4_2
-- GROUP BY raumtyp;
